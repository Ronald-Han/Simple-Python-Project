<!DOCTYPE html>
<html>
<head>
<title>Pomodoro</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<div class="reminder">
<h3>Reminders</h3>
<textarea placeholder="Write here..."></textarea>
</div>

<div class="main">
<h1 id="timer">25:00</h1>

<input id="work" type="number" value="25">
<input id="break" type="number" value="5">

<br><br>

<button onclick="start()">Start</button>
<button onclick="reset()">Reset</button>

<p id="status">Ready</p>
</div>

<script src="script.js"></script>
</body>
</html>


body{
font-family:Arial;
text-align:center;
background:#111;
color:white;
}

.main{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
}

.reminder{
position:absolute;
top:10px;
right:10px;
width:200px;
}

textarea{
width:100%;
height:60px;
}


let timer, time = 1500, mode = "work";

function start(){
clearInterval(timer);

let work = document.getElementById("work").value * 60;
let brk = document.getElementById("break").value * 60;

if(mode=="work") time = work;
else time = brk;

timer = setInterval(()=>{
let min = Math.floor(time/60);
let sec = time%60;

document.getElementById("timer").innerText =
(min<10?"0":"")+min+":"+(sec<10?"0":"")+sec;

time--;

if(time<0){
mode = mode=="work"?"break":"work";
document.getElementById("status").innerText =
mode=="work"?"Focus!":"Break!";
start();
}
},1000);
}

function reset(){
clearInterval(timer);
mode="work";
document.getElementById("timer").innerText="25:00";
document.getElementById("status").innerText="Ready";
}
